{
  "name": "ranking-service",
  "version": "1.0.0",
  "description": "Backend service for scoring GitHub repositories by popularity.",
  "main": "dist/app.js",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:integration": "jest --config jest.integration.config.js",
    "performance": "artillery run performance/repositories.yml",
    "start": "node dist/app.js",
    "dev": "tsx watch src/app.ts"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "redis": "^6.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.14.10",
    "artillery": "^2.0.32",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  },
  "overrides": {
    "@ngneat/falso": {
      "uuid": "^11.1.1"
    }
  },
  "engines": {
    "node": ">=20"
  }
}
